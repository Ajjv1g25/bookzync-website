# BookZync Website — Environment Variables
#
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# The marketing site runs with NONE of these set — they're only needed when
# you wire the chatbot up to a real LLM or add integrations.

# ──────────────────────────────────────────────────────────────────
# Site URL (used in sitemap.xml + robots.txt + OG metadata)
# ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bookzync.com

# ──────────────────────────────────────────────────────────────────
# LLM provider for the chatbot — pick ONE
# ──────────────────────────────────────────────────────────────────
# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT)
# OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────
# Lead capture — pick ONE when ready
# ──────────────────────────────────────────────────────────────────
# Resend (transactional email)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=leads@bookzync.com

# Or a webhook (Zapier, Make, n8n)
# LEADS_WEBHOOK_URL=https://hooks.zapier.com/...

# ──────────────────────────────────────────────────────────────────
# Analytics — pick ONE (or none)
# ──────────────────────────────────────────────────────────────────
# Plausible (privacy-first, recommended)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=bookzync.com

# PostHog
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-...
